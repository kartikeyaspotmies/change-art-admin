# ──────────────────────────────────────────────────────────────
# API
# ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Better Auth (cookie name used by backend)
# ──────────────────────────────────────────────────────────────
VITE_AUTH_COOKIE_NAME=better-auth.session_token

# ──────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (web push)
# ──────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ──────────────────────────────────────────────────────────────
# File uploads (tus protocol — backend issues presigned chunks)
# ──────────────────────────────────────────────────────────────
VITE_UPLOAD_CHUNK_SIZE_BYTES=5242880

# ──────────────────────────────────────────────────────────────
# Branding / Defaults
# ──────────────────────────────────────────────────────────────
VITE_DEFAULT_CURRENCY=INR
VITE_DEFAULT_LOCALE=en-IN
VITE_APP_NAME=Creative Production Platform
